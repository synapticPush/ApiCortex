{
  "name": "apicortex-dbmanage",
  "version": "1.0.0",
  "packageManager": "bun@1.3.4",
  "private": true,
  "scripts": {
    "db:generate:core": "drizzle-kit generate --config=drizzle.core.config.ts",
    "db:push:core": "drizzle-kit push --config=drizzle.core.config.ts",
    "db:migrate:core": "drizzle-kit migrate --config=drizzle.core.config.ts",
    "db:generate:timescale": "drizzle-kit generate --config=drizzle.timescale.config.ts",
    "db:push:timescale": "drizzle-kit push --config=drizzle.timescale.config.ts",
    "db:migrate:timescale": "drizzle-kit migrate --config=drizzle.timescale.config.ts",
    "db:hypertable:timescale": "bun run src/timescale/ensureHypertable.ts",
    "db:sync:timescale": "bun run db:push:timescale; bun run db:hypertable:timescale",
    "db:inspect:timescale": "bun run src/timescale/inspect.ts",
    "db:studio:core": "drizzle-kit studio --config=drizzle.core.config.ts",
    "db:studio:timescale": "drizzle-kit studio --config=drizzle.timescale.config.ts"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.44.5",
    "pg": "^8.14.1"
  },
  "devDependencies": {
    "drizzle-kit": "^0.31.4",
    "typescript": "^5.8.2"
  }
}